<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Endpoint Blog</title>
    <style>
      body {
        margin: 0;
        min-height: 100vh;
        display: grid;
        place-items: center;
        font-family: "IBM Plex Sans", "Segoe UI", sans-serif;
        background: linear-gradient(180deg, #f8f3ec 0%, #f1ebe2 100%);
        color: #1a141e;
      }

      main {
        width: min(680px, calc(100% - 32px));
        padding: 40px;
        border-radius: 32px;
        background: rgba(255, 255, 255, 0.76);
        border: 1px solid rgba(26, 20, 30, 0.08);
        box-shadow: 0 24px 80px rgba(26, 20, 30, 0.08);
      }

      h1 {
        margin: 0;
        font-size: clamp(2.8rem, 8vw, 4.5rem);
        letter-spacing: -0.05em;
        line-height: 0.95;
      }

      p {
        margin: 16px 0 0;
        font-size: 1.05rem;
        line-height: 1.7;
        color: rgba(26, 20, 30, 0.72);
      }

      a {
        display: inline-block;
        margin-top: 24px;
        color: inherit;
        text-decoration: none;
        border: 1px solid rgba(26, 20, 30, 0.12);
        border-radius: 999px;
        padding: 12px 18px;
      }
    </style>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@400;500;700&display=swap" rel="stylesheet" />
  </head>
  <body>
    <main>
      <h1>Blog</h1>
      <p>This route is here so the copied navigation behaves cleanly. If you want, I can also recreate the archived blog index and posts next.</p>
      <a href="/">Back to home</a>
    </main>
  </body>
</html>
