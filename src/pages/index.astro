---
const useCases = [
  { label: "Comparative effectiveness", icon: "bars" },
  { label: "Real-world outcomes", icon: "list" },
  { label: "Label expansion", icon: "chart" },
  { label: "Map unmet needs", icon: "eye" },
  { label: "Biomarker strategy", icon: "spark" },
  { label: "Indication selection", icon: "target" },
  { label: "Trial design", icon: "grid" },
  { label: "Trial recruitment", icon: "users" },
  { label: "Market access", icon: "arrow" },
  { label: "Close care gaps", icon: "plus" },
];

const studyPrompts = [
  "Give Endpoint a study to work on...",
  "Compare treatment sequencing in metastatic CRC...",
  "Quantify response durability after line progression...",
  "Measure care gaps across multimodal cohorts...",
];

const therapeuticAreas = [
  {
    tag: "Oncology",
    title: "Cancer",
    body:
      "Model treatment patterns, line progression, and outcome signals across complex multimodal patient journeys.",
  },
  {
    tag: "Virology",
    title: "Infectious disease",
    body:
      "Track disease burden, adherence, and treatment response across longitudinal, real-world cohorts.",
  },
  {
    tag: "Cardiometabolic",
    title: "Metabolic disease",
    body:
      "Surface care gaps, risk trajectories, and intervention opportunities from deeply linked records.",
  },
];

function iconMarkup(icon: string) {
  switch (icon) {
    case "bars":
      return `<svg viewBox="0 0 18 18" aria-hidden="true"><path d="M3 4.5h12M3 9h8.5M3 13.5h6" /></svg>`;
    case "list":
      return `<svg viewBox="0 0 18 18" aria-hidden="true"><path d="M4 4h10M4 9h10M4 14h10" /><circle cx="2.5" cy="4" r=".75"/><circle cx="2.5" cy="9" r=".75"/><circle cx="2.5" cy="14" r=".75"/></svg>`;
    case "chart":
      return `<svg viewBox="0 0 18 18" aria-hidden="true"><path d="M3 14.5 7 10l3 2.5 5-6" /><path d="M3 3v12h12" /></svg>`;
    case "eye":
      return `<svg viewBox="0 0 18 18" aria-hidden="true"><path d="M1.8 9S4.5 4.5 9 4.5 16.2 9 16.2 9 13.5 13.5 9 13.5 1.8 9 1.8 9Z"/><circle cx="9" cy="9" r="2.1"/></svg>`;
    case "spark":
      return `<svg viewBox="0 0 18 18" aria-hidden="true"><path d="m9 2 1.4 4.6L15 8l-4.6 1.4L9 14l-1.4-4.6L3 8l4.6-1.4L9 2Z"/></svg>`;
    case "target":
      return `<svg viewBox="0 0 18 18" aria-hidden="true"><circle cx="9" cy="9" r="6"/><circle cx="9" cy="9" r="3"/><path d="M9 1.5v2.1M9 14.4v2.1M1.5 9h2.1M14.4 9h2.1"/></svg>`;
    case "grid":
      return `<svg viewBox="0 0 18 18" aria-hidden="true"><rect x="3" y="3" width="4.2" height="4.2"/><rect x="10.8" y="3" width="4.2" height="4.2"/><rect x="3" y="10.8" width="4.2" height="4.2"/><rect x="10.8" y="10.8" width="4.2" height="4.2"/></svg>`;
    case "users":
      return `<svg viewBox="0 0 18 18" aria-hidden="true"><circle cx="6.2" cy="6.4" r="2.1"/><circle cx="12" cy="7.3" r="1.8"/><path d="M2.7 14.2c.4-2.2 2-3.5 4.4-3.5s4 1.3 4.4 3.5"/><path d="M10.4 14.2c.3-1.6 1.4-2.6 3.1-2.6 1.1 0 1.9.3 2.4.9"/></svg>`;
    case "arrow":
      return `<svg viewBox="0 0 18 18" aria-hidden="true"><path d="M3 14.5 14.2 3.3M8.8 3.3h5.4v5.4"/></svg>`;
    default:
      return `<svg viewBox="0 0 18 18" aria-hidden="true"><path d="M9 3v12M3 9h12"/></svg>`;
  }
}
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>Endpoint</title>
    <meta
      name="description"
      content="Conduct any RWE study in minutes with Endpoint's AI-powered platform and multimodal patient record network."
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500;700&display=swap"
      rel="stylesheet"
    />
    <style>
      :root {
        --bg: #f6f5f1;
        --ink: #1f212a;
        --muted: #65676f;
        --line: rgba(80, 80, 80, 0.14);
        --lavender: #aa8fff;
        --lavender-soft: rgba(170, 143, 255, 0.18);
        --shadow: 0 12px 30px rgba(33, 31, 31, 0.08);
        --container: 1200px;
        --square-scale: 1;
        --square-rotate: 0deg;
        --mission-bg: 0;
      }

      * { box-sizing: border-box; }
      html { scroll-behavior: smooth; }
      body {
        margin: 0;
        color: var(--ink);
        background: var(--bg);
        font-family: "IBM Plex Sans", sans-serif;
      }
      a { color: inherit; text-decoration: none; }
      .page { min-height: 100vh; overflow-x: clip; }
      .shell { width: min(var(--container), calc(100% - 40px)); margin: 0 auto; }
      .nav-wrap { position: sticky; top: 20px; z-index: 40; padding-top: 20px; }
      .nav {
        display: flex; align-items: center; justify-content: space-between; gap: 18px; padding: 18px 24px;
        border: 1px solid var(--line); border-radius: 16px; background: rgba(255, 255, 255, 0.25);
        backdrop-filter: blur(25px); -webkit-backdrop-filter: blur(25px);
      }
      .logo { display: inline-flex; align-items: center; min-height: 28px; }
      .logo-word {
        display: inline-block;
        font-size: 2rem;
        line-height: 1;
        letter-spacing: -0.08em;
        font-weight: 600;
      }
      .nav-links { display: flex; align-items: center; gap: 28px; }
      .nav-links .blog-link { font-size: 1.5rem; }
      .button {
        display: inline-flex; align-items: center; justify-content: center; gap: 10px; min-height: 56px; padding: 0 20px;
        border-radius: 8px; border: 1px solid transparent; font-size: 1.25rem;
        transition: transform 220ms ease, box-shadow 220ms ease;
      }
      .button:hover { transform: translateY(-1px); }
      .button.primary { background: var(--lavender); color: white; }
      .button.secondary { background: white; border-color: rgba(75, 85, 99, 0.25); }
      .hero { padding: 80px 0 70px; }
      .hero-grid { display: grid; grid-template-columns: minmax(0, 1.06fr) minmax(360px, 0.94fr); align-items: start; gap: 48px; }
      .eyebrow {
        display: inline-flex; align-items: center; gap: 10px; font-family: "IBM Plex Mono", monospace;
        font-size: 0.86rem; letter-spacing: 0.12em; text-transform: uppercase; color: rgba(31, 33, 42, 0.74);
      }
      .eyebrow svg { width: 15px; height: 15px; }
      .hero-copy { padding-top: 38px; }
      .hero-copy h1 {
        margin: 18px 0 0; max-width: 11ch; font-size: clamp(3.8rem, 8vw, 6.6rem); line-height: 0.95;
        letter-spacing: -0.065em; font-weight: 500;
      }
      .hero-subtitle { margin: 28px 0 0; max-width: 30rem; font-size: 1.55rem; line-height: 1.28; color: var(--muted); }
      .hero-actions { display: flex; flex-wrap: wrap; gap: 16px; margin-top: 30px; }
      .hero-note { margin-top: 26px; color: rgba(31, 33, 42, 0.55); font-size: 0.95rem; }
      .hero-visual { position: relative; display: grid; gap: 16px; }
      .data-card {
        position: relative; min-height: 420px; padding: 22px; border-radius: 22px;
        background: linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(249, 248, 245, 0.88));
        border: 1px solid rgba(75, 85, 99, 0.16); box-shadow: 0 20px 40px rgba(33, 31, 31, 0.08); overflow: hidden;
      }
      .data-card::before {
        content: ""; position: absolute; inset: 0;
        background:
          radial-gradient(circle at 20% 20%, rgba(170, 143, 255, 0.22), transparent 32%),
          radial-gradient(circle at 80% 28%, rgba(193, 187, 249, 0.18), transparent 26%),
          linear-gradient(180deg, rgba(255, 255, 255, 0.4), transparent 60%);
      }
      .data-label {
        position: relative; z-index: 1; display: flex; justify-content: space-between; align-items: center; gap: 12px;
        font-family: "IBM Plex Mono", monospace; font-size: 0.86rem; text-transform: uppercase; letter-spacing: 0.11em;
        color: rgba(31, 33, 42, 0.68);
      }
      .network-grid {
        position: absolute; inset: 62px 24px 24px; border-radius: 18px; border: 1px solid rgba(75, 85, 99, 0.12);
        background:
          linear-gradient(rgba(99, 99, 99, 0.08) 1px, transparent 1px),
          linear-gradient(90deg, rgba(99, 99, 99, 0.08) 1px, transparent 1px);
        background-size: 52px 52px; overflow: hidden;
      }
      .network-path,.network-node { position: absolute; }
      .network-path {
        height: 1px; background: linear-gradient(90deg, rgba(31, 33, 42, 0.22), rgba(170, 143, 255, 0.92));
        transform-origin: left center; opacity: 0.62;
      }
      .network-node {
        width: 14px; height: 14px; border-radius: 50%; background: var(--lavender);
        box-shadow: 0 0 0 0 rgba(170, 143, 255, 0.18); animation: nodePulse 4.5s infinite ease-in-out;
      }
      .network-node.dark { background: var(--ink); }
      .network-node:nth-of-type(2) { animation-delay: -1.1s; }
      .network-node:nth-of-type(3) { animation-delay: -2.2s; }
      .network-node:nth-of-type(4) { animation-delay: -3.3s; }
      .mini-grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 16px; }
      .mini-card {
        position: relative; min-height: 152px; padding: 18px; border-radius: 18px; border: 1px solid rgba(75, 85, 99, 0.15);
        background: rgba(255, 255, 255, 0.76); overflow: hidden;
      }
      .mini-card .title {
        position: relative; z-index: 1; font-family: "IBM Plex Mono", monospace; font-size: 0.76rem;
        letter-spacing: 0.09em; text-transform: uppercase; color: rgba(31, 33, 42, 0.66);
      }
      .mini-card .graphic { position: absolute; inset: 42px 16px 16px; }
      .orbit-ring,.target-ring { position: absolute; inset: 0; border-radius: 999px; border: 1px dashed rgba(75, 85, 99, 0.2); }
      .orbit-core {
        position: absolute; top: calc(50% - 14px); left: calc(50% - 14px); width: 28px; height: 28px; border-radius: 50%;
        background: var(--lavender); box-shadow: 0 0 0 14px rgba(170, 143, 255, 0.16), 0 0 0 38px rgba(170, 143, 255, 0.08);
      }
      .orbit-particle {
        position: absolute; top: calc(50% - 4px); left: calc(50% - 4px); width: 8px; height: 8px; border-radius: 50%;
        background: var(--ink); transform-origin: 0 0; animation: orbit 6s linear infinite;
      }
      .target-line,.wave { position: absolute; inset: 16px; }
      .target-line svg,.wave svg { width: 100%; height: 100%; }
      .wave path { animation: dashShift 8s linear infinite; }
      .mission-section { position: relative; height: 320vh; }
      .mission-sticky {
        position: sticky; top: 0; display: grid; place-items: center; min-height: 100vh; overflow: hidden;
        background:
          radial-gradient(circle at 50% 50%, rgba(170, 143, 255, 0.15), transparent 22%),
          linear-gradient(180deg, rgba(31, 33, 42, calc(0.08 + var(--mission-bg) * 0.5)), rgba(31, 33, 42, calc(0.72 + var(--mission-bg) * 0.2)));
      }
      .mission-shell {
        position: relative; z-index: 1; width: min(1200px, calc(100% - 40px)); min-height: 100vh; display: grid; place-items: center;
      }
      .mission-visual { position: absolute; width: clamp(195px, 14vw, 240px); aspect-ratio: 1; display: grid; place-items: center; }
      .mission-square {
        width: 80%; height: 80%; border: 1px solid transparent; border-image: linear-gradient(135deg, #fff, #c1bbf9, #aa8fff) 1;
        transform: scale(var(--square-scale)) rotate(var(--square-rotate)); opacity: calc(0.25 + var(--mission-bg) * 0.75);
        box-shadow: 0 0 0 1px rgba(255, 255, 255, 0.08), 0 0 40px rgba(170, 143, 255, calc(0.08 + var(--mission-bg) * 0.22));
      }
      .mission-copy { position: absolute; width: min(1040px, calc(100% - 56px)); display: grid; gap: 24px; justify-items: center; text-align: center; }
      .mission-line {
        max-width: 17ch; font-size: clamp(2.4rem, 4.1vw, 3.8rem); line-height: 1.08; letter-spacing: -0.05em; color: white;
        opacity: 0; transform: translateY(18px); transition: opacity 240ms linear, transform 240ms linear;
      }
      .mission-line.active { opacity: 1; transform: translateY(0); }
      .mission-line.is-lavender strong { color: var(--lavender); font-weight: 500; }
      .platform { padding: 84px 0 28px; }
      .platform-shell {
        padding: 72px 34px 34px; border-radius: 34px;
        background: radial-gradient(circle at 50% 0%, rgba(170, 143, 255, 0.12), transparent 30%), linear-gradient(180deg, #212121, #1a1a1a);
        color: white; overflow: hidden;
      }
      .platform-heading { display: grid; justify-items: center; gap: 8px; text-align: center; }
      .platform-heading p { margin: 0; font-size: clamp(2.5rem, 4vw, 3.7rem); line-height: 1; letter-spacing: -0.06em; }
      .platform-heading .lavender { color: var(--lavender); }
      .platform-display { display: grid; grid-template-columns: minmax(0, 1.04fr) minmax(320px, 0.96fr); gap: 26px; margin-top: 38px; }
      .display-frame {
        position: relative; min-height: 520px; border-radius: 28px; background: linear-gradient(180deg, rgba(255, 255, 255, 0.06), rgba(255, 255, 255, 0.02));
        border: 1px solid rgba(255, 255, 255, 0.08); overflow: hidden;
      }
      .display-frame canvas { position: absolute; inset: 0; width: 100%; height: 100%; }
      .display-caption { position: absolute; top: 28px; left: 28px; right: 28px; display: grid; gap: 18px; z-index: 1; }
      .display-caption p { margin: 0; color: #8b8a87; font-size: 1.5rem; }
      .study-input {
        display: flex; align-items: center; gap: 12px; min-height: 64px; padding: 0 16px; border-radius: 8px; background: white;
        border: 1px solid rgba(75, 85, 99, 0.3); box-shadow: 0 0 6px 1px rgba(75, 85, 99, 0.1); color: #6b7280;
      }
      .study-input .text { flex: 1; min-width: 0; font-size: 0.95rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
      .study-input .go { width: 24px; height: 24px; flex: none; }
      .platform-side { display: grid; align-content: start; gap: 24px; }
      .unlock-copy h3 { margin: 0; font-size: clamp(2.2rem, 3vw, 3.3rem); line-height: 0.95; letter-spacing: -0.06em; font-weight: 500; }
      .unlock-copy h3 span { color: var(--lavender); }
      .use-case-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 14px; }
      .use-card {
        display: flex; align-items: center; gap: 12px; min-height: 84px; padding: 18px 16px; border-radius: 18px;
        border: 1px solid rgba(255, 255, 255, 0.11); background: rgba(246, 245, 241, 0.07);
      }
      .use-card .icon { width: 36px; height: 36px; display: grid; place-items: center; border-radius: 10px; background: rgba(255, 255, 255, 0.06); }
      .use-card svg { width: 18px; height: 18px; stroke: white; fill: none; stroke-width: 1.35; stroke-linecap: round; stroke-linejoin: round; }
      .use-card p { margin: 0; font-size: 0.95rem; color: rgba(246, 245, 241, 0.95); }
      .stats-section { padding: 28px 0; }
      .stats-shell { display: grid; grid-template-columns: minmax(0, 0.96fr) minmax(280px, 1.04fr); gap: 20px; }
      .stats-copy,.stats-grid {
        padding: 30px; border-radius: 28px; background: white; border: 1px solid rgba(80, 80, 80, 0.1); box-shadow: var(--shadow);
      }
      .stats-copy h2,.areas-header h2 {
        margin: 14px 0 0; font-size: clamp(2.2rem, 3.7vw, 3.8rem); line-height: 0.98; letter-spacing: -0.06em; font-weight: 500;
      }
      .stats-copy p,.area-card p,.footer-card p { margin: 18px 0 0; color: var(--muted); line-height: 1.55; font-size: 1rem; }
      .stats-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 18px; }
      .stat-card { min-height: 168px; padding: 24px; border-radius: 22px; background: #f7f6f2; border: 1px solid rgba(75, 85, 99, 0.08); }
      .stat-card strong {
        display: block; font-size: clamp(2.8rem, 5vw, 4.7rem); line-height: 0.95; letter-spacing: -0.07em; font-weight: 500;
      }
      .stat-card span { display: block; margin-top: 10px; color: var(--muted); }
      .areas { padding: 44px 0 80px; }
      .areas-header { max-width: 760px; }
      .areas-grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 18px; margin-top: 24px; }
      .area-card {
        position: relative; min-height: 320px; padding: 24px; border-radius: 24px; background: white;
        border: 1px solid rgba(75, 85, 99, 0.1); box-shadow: var(--shadow); overflow: hidden;
      }
      .area-tag {
        display: inline-flex; padding: 8px 12px; border-radius: 999px; background: var(--lavender-soft);
        font-family: "IBM Plex Mono", monospace; font-size: 0.74rem; letter-spacing: 0.08em; text-transform: uppercase;
      }
      .area-card h3 { margin: 18px 0 0; font-size: 2rem; line-height: 0.98; letter-spacing: -0.05em; font-weight: 500; }
      .area-graphic {
        position: absolute; left: 24px; right: 24px; bottom: 24px; height: 110px; border-radius: 26px;
        background:
          radial-gradient(circle at 18% 50%, rgba(170, 143, 255, 0.95) 0 12%, transparent 13%),
          radial-gradient(circle at 50% 50%, rgba(31, 33, 42, 0.16) 0 10%, transparent 11%),
          radial-gradient(circle at 82% 50%, rgba(193, 187, 249, 0.8) 0 14%, transparent 15%),
          linear-gradient(90deg, rgba(31, 33, 42, 0.08), rgba(170, 143, 255, 0.25), rgba(31, 33, 42, 0.08));
        animation: drift 10s ease-in-out infinite;
      }
      .area-card:nth-child(2) .area-graphic { animation-delay: -3s; }
      .area-card:nth-child(3) .area-graphic { animation-delay: -6s; }
      .footer { padding-bottom: 40px; }
      .footer-card {
        display: flex; align-items: center; justify-content: space-between; gap: 20px; padding: 28px 30px; border-radius: 24px;
        background: linear-gradient(180deg, #212121, #1b1b1d); color: white;
      }
      .footer-card p { color: rgba(255, 255, 255, 0.7); }
      .footer-meta { margin-top: 12px; font-family: "IBM Plex Mono", monospace; font-size: 0.8rem; color: rgba(255, 255, 255, 0.52); }
      [data-reveal] { opacity: 0; transform: translateY(18px); transition: opacity 600ms ease, transform 600ms ease; }
      [data-reveal].is-visible { opacity: 1; transform: translateY(0); }
      @keyframes nodePulse {
        0%,100% { transform: scale(1); box-shadow: 0 0 0 0 rgba(170, 143, 255, 0.18); }
        50% { transform: scale(1.08); box-shadow: 0 0 0 14px rgba(170, 143, 255, 0); }
      }
      @keyframes orbit {
        from { transform: rotate(0deg) translateX(42px) rotate(0deg); }
        to { transform: rotate(360deg) translateX(42px) rotate(-360deg); }
      }
      @keyframes dashShift { from { stroke-dashoffset: 0; } to { stroke-dashoffset: -180; } }
      @keyframes drift {
        0%,100% { transform: translate3d(0,0,0) scale(1); }
        50% { transform: translate3d(0,-6px,0) scale(1.02); }
      }
      @media (max-width: 1080px) {
        .hero-grid,.platform-display,.stats-shell,.areas-grid { grid-template-columns: 1fr; }
        .display-frame { min-height: 460px; }
      }
      @media (max-width: 809px) {
        .shell,.mission-shell { width: min(100% - 24px, var(--container)); }
        .nav-wrap { top: 12px; padding-top: 12px; }
        .nav { padding: 14px 16px; }
        .nav-links { gap: 14px; }
        .nav-links .blog-link { font-size: 1.25rem; }
        .button { min-height: 48px; font-size: 1rem; }
        .hero { padding-top: 46px; }
        .hero-copy { padding-top: 18px; }
        .hero-subtitle { font-size: 1.2rem; }
        .mini-grid,.use-case-grid,.stats-grid { grid-template-columns: 1fr; }
        .mission-line { font-size: clamp(2rem, 8vw, 2.6rem); }
        .platform-shell { padding: 42px 18px 18px; border-radius: 24px; }
        .display-frame { min-height: 400px; }
        .display-caption p { font-size: 0.95rem; }
        .stats-copy,.stats-grid,.area-card,.footer-card { padding: 22px; }
        .footer-card { flex-direction: column; align-items: stretch; }
      }
    </style>
  </head>
  <body>
    <div class="page">
      <header class="nav-wrap shell">
        <div class="nav" data-reveal>
          <a class="logo" href="#top" aria-label="Endpoint home"><span class="logo-word">Endpoint</span></a>

          <nav class="nav-links" aria-label="Primary">
            <a class="blog-link" href="/blog">Blog</a>
            <a class="button primary" href="https://cal.com/luis-pericchi/30min" target="_blank" rel="noreferrer">
              <span>Book a call</span>
            </a>
          </nav>
        </div>
      </header>

      <main id="top">
        <section class="hero shell">
          <div class="hero-grid">
            <div class="hero-copy" data-reveal>
              <div class="eyebrow">
                <svg viewBox="0 0 15 15" fill="none" aria-hidden="true">
                  <rect x="1.5" y="1.5" width="12" height="12" stroke="currentColor" stroke-width="1.2"></rect>
                </svg>
                <span>The Endpoint Data Network</span>
              </div>

              <h1>Conduct any RWE study in minutes</h1>
              <p class="hero-subtitle">
                Scale evidence generation with our AI-powered platform, delivering instant insights from 25M+
                multimodal, longitudinal patient records.
              </p>

              <div class="hero-actions">
                <a class="button primary" href="https://cal.com/luis-pericchi/30min" target="_blank" rel="noreferrer">
                  <span>Book a call</span>
                </a>
                <a class="button secondary" href="#platform">See the platform</a>
              </div>

              <div class="hero-note">Archive-style hierarchy and motion rebuilt much more closely, especially the sticky scroll section.</div>
            </div>

            <div class="hero-visual" data-reveal>
              <div class="data-card">
                <div class="data-label">
                  <span>The Endpoint Data Network</span>
                  <strong>25M+</strong>
                </div>

                <div class="network-grid" aria-hidden="true">
                  <div class="network-path" style="top: 23%; left: 19%; width: 34%; transform: rotate(12deg);"></div>
                  <div class="network-path" style="top: 33%; left: 49%; width: 28%; transform: rotate(-24deg);"></div>
                  <div class="network-path" style="top: 67%; left: 24%; width: 44%; transform: rotate(-7deg);"></div>
                  <div class="network-path" style="top: 54%; left: 39%; width: 22%; transform: rotate(64deg);"></div>
                  <div class="network-node" style="top: 20%; left: 16%;"></div>
                  <div class="network-node dark" style="top: 31%; left: 52%;"></div>
                  <div class="network-node" style="top: 58%; left: 36%;"></div>
                  <div class="network-node dark" style="top: 66%; left: 66%;"></div>
                </div>
              </div>

              <div class="mini-grid">
                <div class="mini-card">
                  <div class="title">Biomarker strategy</div>
                  <div class="graphic">
                    <div class="orbit-ring"></div>
                    <div class="orbit-core"></div>
                    <div class="orbit-particle"></div>
                  </div>
                </div>

                <div class="mini-card">
                  <div class="title">Indication selection</div>
                  <div class="graphic target-line">
                    <svg viewBox="0 0 100 100" fill="none" aria-hidden="true">
                      <circle cx="50" cy="50" r="30" stroke="rgba(31,33,42,0.16)" stroke-dasharray="5 5"></circle>
                      <path d="M34 66 56 57 65 34 43 43 34 66Z" fill="#aa8fff"></path>
                      <circle cx="50" cy="50" r="5" fill="#1f212a"></circle>
                    </svg>
                  </div>
                </div>

                <div class="mini-card">
                  <div class="title">Multimodal signals</div>
                  <div class="graphic wave">
                    <svg viewBox="0 0 220 90" fill="none" aria-hidden="true">
                      <path d="M5 53c21-8 42-12 63-12 24 0 40-6 63-11 23-5 42-7 84 12" stroke="#aa8fff" stroke-width="2" stroke-dasharray="8 8"></path>
                      <path d="M5 28c22 10 42 18 65 24 21 5 44 7 66 8 28 1 43 7 79 19" stroke="rgba(31,33,42,0.28)" stroke-width="2" stroke-dasharray="10 9"></path>
                    </svg>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </section>

        <section class="mission-section" id="mission">
          <div class="mission-sticky">
            <div class="mission-shell">
              <div class="mission-visual" aria-hidden="true">
                <div class="mission-square"></div>
              </div>

              <div class="mission-copy">
                <div class="mission-line active" data-mission-line="0">
                  We&apos;re creating a future where every medical decision is backed by reliable science.
                </div>
                <div class="mission-line is-lavender" data-mission-line="1">
                  With evidence that is <strong>instant, personalized, and accessible.</strong>
                </div>
                <div class="mission-line is-lavender" data-mission-line="2">
                  From question to insight, the experience should feel fast, clear, and trustworthy.
                </div>
              </div>
            </div>
          </div>
        </section>

        <section class="platform shell" id="platform">
          <div class="platform-shell" data-reveal>
            <div class="platform-heading">
              <p>Enabled via a <span class="lavender">cutting-edge,</span></p>
              <p><span class="lavender">user-friendly</span> platform</p>
            </div>

            <div class="platform-display">
              <div class="display-frame">
                <canvas id="platformCanvas" width="1200" height="900" aria-hidden="true"></canvas>

                <div class="display-caption">
                  <p>Evidence begins with a research question</p>
                  <div class="study-input">
                    <div class="text" id="studyPrompt">{studyPrompts[0]}</div>
                    <svg class="go" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                      <path d="M5 12h14M19 12l-7-7M19 12l-7 7" stroke="#6B7280" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>
                    </svg>
                  </div>
                </div>
              </div>

              <div class="platform-side">
                <div class="unlock-copy">
                  <h3>That unlocks <span>every drug&apos;s</span> <span>full potential</span></h3>
                </div>

                <div class="use-case-grid" aria-label="Use cases">
                  {useCases.map((item) => (
                    <div class="use-card">
                      <div class="icon" set:html={iconMarkup(item.icon)} />
                      <p>{item.label}</p>
                    </div>
                  ))}
                </div>
              </div>
            </div>
          </div>
        </section>

        <section class="stats-section shell">
          <div class="stats-shell">
            <article class="stats-copy" data-reveal>
              <div class="eyebrow">
                <svg viewBox="0 0 15 15" fill="none" aria-hidden="true">
                  <rect x="1.5" y="1.5" width="12" height="12" stroke="currentColor" stroke-width="1.2"></rect>
                </svg>
                <span>The Endpoint Data Network</span>
              </div>
              <h2>Instant insight from longitudinal, multimodal patient records.</h2>
              <p>
                The archived site presented the network as a compact proof point: broad scale, international coverage,
                and a direct path from study idea to evidence.
              </p>
            </article>

            <div class="stats-grid" data-reveal>
              <div class="stat-card">
                <strong>25M</strong>
                <span>Unique patients in network</span>
              </div>
              <div class="stat-card">
                <strong>8</strong>
                <span>Countries</span>
              </div>
              <div class="stat-card">
                <strong>5B+</strong>
                <span>Clinical events structured for research</span>
              </div>
              <div class="stat-card">
                <strong>24/7</strong>
                <span>Faster iteration from question to answer</span>
              </div>
            </div>
          </div>
        </section>

        <section class="areas shell">
          <div class="areas-header" data-reveal>
            <div class="eyebrow">
              <svg viewBox="0 0 15 15" fill="none" aria-hidden="true">
                <rect x="1.5" y="1.5" width="12" height="12" stroke="currentColor" stroke-width="1.2"></rect>
              </svg>
              <span>Therapeutic areas</span>
            </div>
            <h2>Cancer, virology, and metabolic disease.</h2>
          </div>

          <div class="areas-grid">
            {therapeuticAreas.map((area) => (
              <article class="area-card" data-reveal>
                <span class="area-tag">{area.tag}</span>
                <h3>{area.title}</h3>
                <p>{area.body}</p>
                <div class="area-graphic" aria-hidden="true"></div>
              </article>
            ))}
          </div>
        </section>
      </main>

      <footer class="footer shell">
        <div class="footer-card" data-reveal>
          <div>
            <div class="eyebrow" style="color: rgba(255,255,255,0.68);">
              <svg viewBox="0 0 15 15" fill="none" aria-hidden="true">
                <rect x="1.5" y="1.5" width="12" height="12" stroke="currentColor" stroke-width="1.2"></rect>
              </svg>
              <span>Endpoint</span>
            </div>
            <p>AI-powered real-world evidence for faster, clearer medical decisions.</p>
            <div class="footer-meta">&copy; Endpoint Data Inc 2025</div>
          </div>

          <a class="button primary" href="https://cal.com/luis-pericchi/30min" target="_blank" rel="noreferrer">
            <span>Book a call</span>
          </a>
        </div>
      </footer>
    </div>

    <script define:vars={{ studyPrompts }}>
      const root = document.documentElement;
      const missionSection = document.querySelector(".mission-section");
      const missionLines = Array.from(document.querySelectorAll("[data-mission-line]"));
      const revealTargets = Array.from(document.querySelectorAll("[data-reveal]"));
      const studyPrompt = document.getElementById("studyPrompt");
      const canvas = document.getElementById("platformCanvas");

      const revealObserver = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            if (entry.isIntersecting) {
              entry.target.classList.add("is-visible");
            }
          }
        },
        { threshold: 0.15 }
      );

      for (const target of revealTargets) {
        revealObserver.observe(target);
      }

      function clamp(value, min, max) {
        return Math.min(max, Math.max(min, value));
      }

      function updateMission() {
        if (!missionSection) return;
        const rect = missionSection.getBoundingClientRect();
        const total = missionSection.offsetHeight - window.innerHeight;
        const progress = total > 0 ? clamp(-rect.top / total, 0, 1) : 0;
        const step = Math.min(missionLines.length - 1, Math.floor(progress * missionLines.length));
        root.style.setProperty("--mission-bg", String(progress));
        root.style.setProperty("--square-scale", String(1 + progress * 9.5));
        root.style.setProperty("--square-rotate", `${progress * 52}deg`);
        missionLines.forEach((line, index) => {
          line.classList.toggle("active", index === step || (index === missionLines.length - 1 && progress > 0.92));
        });
        const missionVisual = document.querySelector(".mission-visual");
        if (missionVisual) {
          missionVisual.style.transform = `translateY(${Math.sin(progress * Math.PI) * 6}px)`;
        }
      }

      updateMission();
      window.addEventListener("scroll", updateMission, { passive: true });
      window.addEventListener("resize", updateMission);

      let promptIndex = 0;
      setInterval(() => {
        if (!studyPrompt) return;
        promptIndex = (promptIndex + 1) % studyPrompts.length;
        studyPrompt.textContent = studyPrompts[promptIndex];
      }, 2600);

      if (canvas instanceof HTMLCanvasElement) {
        const context = canvas.getContext("2d");
        const nodes = [
          { x: 0.18, y: 0.72, dx: 0.00023, dy: -0.00017, r: 6, color: "#AA8FFF" },
          { x: 0.32, y: 0.34, dx: 0.00018, dy: 0.00015, r: 7, color: "#F6F5F1" },
          { x: 0.48, y: 0.52, dx: -0.00019, dy: 0.00012, r: 5, color: "#AA8FFF" },
          { x: 0.62, y: 0.23, dx: -0.00016, dy: 0.00019, r: 6, color: "#F6F5F1" },
          { x: 0.74, y: 0.62, dx: 0.00022, dy: -0.00014, r: 8, color: "#AA8FFF" },
          { x: 0.83, y: 0.38, dx: -0.00021, dy: -0.0001, r: 5, color: "#F6F5F1" },
        ];

        function resizeCanvas() {
          const ratio = Math.min(window.devicePixelRatio || 1, 2);
          const rect = canvas.getBoundingClientRect();
          canvas.width = Math.round(rect.width * ratio);
          canvas.height = Math.round(rect.height * ratio);
          context.setTransform(ratio, 0, 0, ratio, 0, 0);
        }

        function draw(timestamp) {
          const rect = canvas.getBoundingClientRect();
          const width = rect.width;
          const height = rect.height;
          context.clearRect(0, 0, width, height);

          const gradient = context.createLinearGradient(0, 0, width, height);
          gradient.addColorStop(0, "rgba(255,255,255,0.04)");
          gradient.addColorStop(0.45, "rgba(170,143,255,0.14)");
          gradient.addColorStop(1, "rgba(255,255,255,0.02)");

          context.strokeStyle = "rgba(255,255,255,0.06)";
          context.lineWidth = 1;
          for (let x = 26; x < width; x += 58) {
            context.beginPath();
            context.moveTo(x, 0);
            context.lineTo(x, height);
            context.stroke();
          }
          for (let y = 32; y < height; y += 58) {
            context.beginPath();
            context.moveTo(0, y);
            context.lineTo(width, y);
            context.stroke();
          }

          context.strokeStyle = gradient;
          context.lineWidth = 1.4;
          context.lineCap = "round";

          for (let i = 0; i < nodes.length; i++) {
            const node = nodes[i];
            node.x += node.dx;
            node.y += node.dy;
            if (node.x < 0.12 || node.x > 0.88) node.dx *= -1;
            if (node.y < 0.16 || node.y > 0.82) node.dy *= -1;

            for (let j = i + 1; j < nodes.length; j++) {
              const other = nodes[j];
              const x1 = node.x * width;
              const y1 = node.y * height;
              const x2 = other.x * width;
              const y2 = other.y * height;
              const distance = Math.hypot(x2 - x1, y2 - y1);

              if (distance < width * 0.34) {
                context.globalAlpha = clamp(1 - distance / (width * 0.34), 0.12, 0.7);
                context.beginPath();
                context.moveTo(x1, y1);
                context.lineTo(x2, y2);
                context.stroke();
              }
            }
          }

          context.globalAlpha = 1;

          for (const node of nodes) {
            const x = node.x * width;
            const y = node.y * height;
            const pulse = 1 + Math.sin(timestamp * 0.0012 + x * 0.01) * 0.14;

            context.fillStyle = node.color;
            context.beginPath();
            context.arc(x, y, node.r * pulse, 0, Math.PI * 2);
            context.fill();

            context.strokeStyle = node.color === "#AA8FFF" ? "rgba(170,143,255,0.3)" : "rgba(255,255,255,0.22)";
            context.lineWidth = 10 * pulse;
            context.globalAlpha = 0.09;
            context.beginPath();
            context.arc(x, y, node.r * 1.7, 0, Math.PI * 2);
            context.stroke();
            context.globalAlpha = 1;
          }

          requestAnimationFrame(draw);
        }

        resizeCanvas();
        window.addEventListener("resize", resizeCanvas);
        requestAnimationFrame(draw);
      }
    </script>
  </body>
</html>
