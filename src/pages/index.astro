---
const useCases = [
  "Comparative effectiveness",
  "Real-world outcomes",
  "Label expansion",
  "Map unmet needs",
  "Biomarker strategy",
  "Indication selection",
  "Trial design",
  "Trial recruitment",
  "Market access",
  "Close care gaps",
];

const therapeuticAreas = [
  {
    name: "Cancer",
    tag: "Oncology",
    description:
      "Model treatment patterns, line progression, and outcome signals across complex multimodal patient journeys.",
  },
  {
    name: "Virology",
    tag: "Infectious Disease",
    description:
      "Track disease burden, treatment response, and adherence trends across longitudinal real-world cohorts.",
  },
  {
    name: "Metabolic disease",
    tag: "Cardiometabolic",
    description:
      "Surface care gaps, risk trajectories, and intervention opportunities from deeply linked records.",
  },
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Endpoint</title>
    <meta
      name="description"
      content="Endpoint accelerates real-world evidence generation with AI-driven insights from 25M+ multimodal, longitudinal patient records."
    />
    <style>
      :root {
        --bg: #f5f0e8;
        --paper: rgba(255, 255, 255, 0.72);
        --ink: #1a141e;
        --muted: rgba(26, 20, 30, 0.68);
        --line: rgba(26, 20, 30, 0.12);
        --lavender: #aa8fff;
        --lavender-soft: rgba(170, 143, 255, 0.18);
        --silver: #d9d9d9;
        --surface: rgba(255, 255, 255, 0.5);
        --surface-strong: #ffffff;
        --shadow: 0 24px 80px rgba(26, 20, 30, 0.08);
        --radius-xl: 40px;
        --radius-lg: 28px;
        --radius-md: 18px;
      }

      * {
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        min-width: 320px;
        color: var(--ink);
        font-family: "IBM Plex Sans", "Segoe UI", sans-serif;
        background:
          radial-gradient(circle at top left, rgba(170, 143, 255, 0.22), transparent 30%),
          radial-gradient(circle at 85% 15%, rgba(255, 255, 255, 0.92), transparent 28%),
          linear-gradient(180deg, #f8f3ec 0%, #f1ebe2 100%);
      }

      body::before {
        content: "";
        position: fixed;
        inset: 0;
        pointer-events: none;
        background-image:
          linear-gradient(rgba(26, 20, 30, 0.035) 1px, transparent 1px),
          linear-gradient(90deg, rgba(26, 20, 30, 0.035) 1px, transparent 1px);
        background-size: 40px 40px;
        opacity: 0.55;
        mask-image: linear-gradient(180deg, rgba(0, 0, 0, 0.8), transparent 85%);
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      .page {
        position: relative;
        overflow: clip;
      }

      .shell {
        width: min(1200px, calc(100% - 32px));
        margin: 0 auto;
      }

      .nav {
        position: sticky;
        top: 16px;
        z-index: 20;
        padding-top: 16px;
      }

      .nav-card {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 18px;
        padding: 16px 20px;
        border: 1px solid rgba(255, 255, 255, 0.7);
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.7);
        backdrop-filter: blur(16px);
        box-shadow: 0 10px 40px rgba(26, 20, 30, 0.06);
      }

      .brand {
        display: inline-flex;
        align-items: center;
        gap: 14px;
        font-family: "IBM Plex Mono", "Courier New", monospace;
        font-size: 0.9rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }

      .brand-mark {
        width: 44px;
        height: 44px;
        border-radius: 14px;
        display: grid;
        place-items: center;
        background: var(--ink);
        color: white;
        flex: none;
      }

      .brand-word {
        font-weight: 700;
      }

      .nav-links {
        display: flex;
        align-items: center;
        gap: 10px;
        flex-wrap: wrap;
        justify-content: flex-end;
      }

      .nav-links a,
      .button {
        border-radius: 999px;
        padding: 11px 16px;
        border: 1px solid var(--line);
        background: rgba(255, 255, 255, 0.7);
        font-size: 0.95rem;
        transition: transform 180ms ease, border-color 180ms ease, background 180ms ease;
      }

      .nav-links a:hover,
      .button:hover {
        transform: translateY(-1px);
        border-color: rgba(26, 20, 30, 0.26);
      }

      .button.primary {
        background: var(--ink);
        color: white;
        border-color: var(--ink);
      }

      .hero {
        padding: 84px 0 48px;
      }

      .hero-grid {
        display: grid;
        grid-template-columns: 1.15fr 0.85fr;
        gap: 26px;
        align-items: stretch;
      }

      .hero-card,
      .network-card,
      .mission-card,
      .platform-card,
      .area-card,
      .footer-card {
        position: relative;
        border-radius: var(--radius-xl);
        border: 1px solid rgba(255, 255, 255, 0.65);
        background: linear-gradient(180deg, rgba(255, 255, 255, 0.72), rgba(255, 255, 255, 0.48));
        box-shadow: var(--shadow);
        overflow: hidden;
      }

      .hero-card {
        padding: 44px;
        min-height: 620px;
      }

      .eyebrow,
      .mono {
        font-family: "IBM Plex Mono", "Courier New", monospace;
        text-transform: uppercase;
        letter-spacing: 0.16em;
        font-size: 0.77rem;
        color: var(--muted);
      }

      h1,
      h2,
      h3 {
        margin: 0;
        line-height: 0.95;
        letter-spacing: -0.05em;
      }

      .hero h1 {
        margin-top: 18px;
        font-size: clamp(3.8rem, 8vw, 6.8rem);
        max-width: 10ch;
      }

      .hero-copy {
        margin-top: 24px;
        max-width: 40rem;
        font-size: 1.15rem;
        line-height: 1.6;
        color: var(--muted);
      }

      .hero-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 14px;
        margin-top: 30px;
      }

      .hero-scroll {
        position: absolute;
        left: 44px;
        bottom: 32px;
        display: inline-flex;
        align-items: center;
        gap: 12px;
      }

      .hero-scroll::before {
        content: "";
        width: 52px;
        height: 52px;
        border-radius: 999px;
        border: 1px solid var(--line);
        background:
          radial-gradient(circle at 50% 35%, var(--lavender) 0 18%, transparent 18%),
          white;
        animation: pulse 2.8s ease-in-out infinite;
      }

      .hero-visual {
        padding: 28px;
        display: grid;
        gap: 18px;
        min-height: 620px;
      }

      .hero-visual .panel {
        border-radius: calc(var(--radius-xl) - 10px);
        border: 1px solid rgba(26, 20, 30, 0.08);
        background: linear-gradient(180deg, rgba(255, 255, 255, 0.86), rgba(255, 255, 255, 0.54));
        position: relative;
        overflow: hidden;
      }

      .hero-visual .panel.main {
        min-height: 360px;
        padding: 28px;
      }

      .hero-visual .panel-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 18px;
      }

      .signal-map {
        position: absolute;
        inset: 0;
        background:
          radial-gradient(circle at 30% 38%, rgba(170, 143, 255, 0.35), transparent 22%),
          radial-gradient(circle at 68% 28%, rgba(26, 20, 30, 0.16), transparent 18%),
          radial-gradient(circle at 74% 72%, rgba(170, 143, 255, 0.22), transparent 20%);
      }

      .signal-grid {
        position: absolute;
        inset: 24px;
        border-radius: 28px;
        border: 1px dashed rgba(26, 20, 30, 0.12);
      }

      .signal-node {
        position: absolute;
        width: 16px;
        height: 16px;
        border-radius: 50%;
        background: var(--lavender);
        box-shadow: 0 0 0 10px rgba(170, 143, 255, 0.12);
      }

      .signal-node.dark {
        background: var(--ink);
        box-shadow: 0 0 0 10px rgba(26, 20, 30, 0.08);
      }

      .signal-line {
        position: absolute;
        height: 1px;
        background: linear-gradient(90deg, rgba(26, 20, 30, 0.15), rgba(170, 143, 255, 0.55));
        transform-origin: left center;
      }

      .panel-label {
        position: relative;
        z-index: 1;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 12px;
      }

      .mini-orbit,
      .mini-compass,
      .mini-wave {
        min-height: 160px;
        padding: 18px;
      }

      .mini-orbit::before,
      .mini-compass::before,
      .mini-wave::before {
        content: "";
        position: absolute;
        inset: 18px;
        border-radius: 24px;
        border: 1px dashed rgba(26, 20, 30, 0.12);
      }

      .mini-orbit::after {
        content: "";
        position: absolute;
        width: 28px;
        height: 28px;
        border-radius: 50%;
        background: var(--lavender);
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        box-shadow:
          0 0 0 22px rgba(170, 143, 255, 0.14),
          0 0 0 54px rgba(170, 143, 255, 0.08);
      }

      .mini-compass svg,
      .mini-wave svg {
        position: absolute;
        inset: 20px;
        width: calc(100% - 40px);
        height: calc(100% - 40px);
      }

      section {
        padding: 24px 0;
      }

      .mission-card {
        display: grid;
        grid-template-columns: 0.9fr 1.1fr;
        gap: 0;
      }

      .mission-copy {
        padding: 42px;
        border-right: 1px solid rgba(26, 20, 30, 0.08);
      }

      .mission-copy h2,
      .platform-copy h2,
      .network-copy h2,
      .areas-header h2 {
        font-size: clamp(2.5rem, 5vw, 4.5rem);
      }

      .mission-copy p,
      .platform-copy p,
      .network-copy p,
      .area-card p,
      .footer-copy p {
        margin-top: 18px;
        font-size: 1.08rem;
        line-height: 1.7;
        color: var(--muted);
      }

      .mission-quote {
        padding: 42px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, rgba(170, 143, 255, 0.18), rgba(255, 255, 255, 0.32));
      }

      .mission-quote p {
        max-width: 22rem;
        margin: 0;
        font-size: clamp(1.5rem, 3vw, 2.3rem);
        line-height: 1.2;
        letter-spacing: -0.04em;
      }

      .platform-card {
        display: grid;
        grid-template-columns: 0.9fr 1.1fr;
      }

      .platform-copy {
        padding: 42px;
        border-right: 1px solid rgba(26, 20, 30, 0.08);
      }

      .use-case-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 12px;
        margin-top: 28px;
      }

      .use-case {
        padding: 16px 18px;
        border-radius: 18px;
        background: rgba(255, 255, 255, 0.62);
        border: 1px solid rgba(26, 20, 30, 0.08);
        font-family: "IBM Plex Mono", "Courier New", monospace;
        font-size: 0.94rem;
      }

      .platform-visual {
        position: relative;
        min-height: 620px;
        padding: 24px;
        display: grid;
        gap: 18px;
        background:
          linear-gradient(180deg, rgba(26, 20, 30, 0.98), rgba(26, 20, 30, 0.9)),
          var(--ink);
        color: white;
      }

      .platform-visual .diagram {
        position: relative;
        border-radius: 30px;
        border: 1px solid rgba(255, 255, 255, 0.08);
        background:
          radial-gradient(circle at 20% 30%, rgba(170, 143, 255, 0.22), transparent 18%),
          radial-gradient(circle at 75% 64%, rgba(170, 143, 255, 0.14), transparent 24%),
          rgba(255, 255, 255, 0.03);
        min-height: 320px;
        overflow: hidden;
      }

      .platform-visual .diagram::before {
        content: "";
        position: absolute;
        inset: 20px;
        border-radius: 22px;
        border: 1px dashed rgba(255, 255, 255, 0.12);
      }

      .diagram-center {
        position: absolute;
        inset: 0;
        display: grid;
        place-items: center;
      }

      .diagram-core {
        width: 160px;
        aspect-ratio: 1;
        border-radius: 50%;
        display: grid;
        place-items: center;
        background:
          radial-gradient(circle at center, rgba(170, 143, 255, 0.95) 0 26%, rgba(170, 143, 255, 0.2) 26% 46%, transparent 46%),
          rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.12);
        font-family: "IBM Plex Mono", "Courier New", monospace;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        text-align: center;
        padding: 12px;
      }

      .diagram-chip {
        position: absolute;
        padding: 10px 14px;
        border-radius: 999px;
        border: 1px solid rgba(255, 255, 255, 0.12);
        background: rgba(255, 255, 255, 0.05);
        font-size: 0.88rem;
        color: rgba(255, 255, 255, 0.88);
      }

      .network-card {
        display: grid;
        grid-template-columns: 0.95fr 1.05fr;
      }

      .network-copy {
        padding: 42px;
        border-right: 1px solid rgba(26, 20, 30, 0.08);
      }

      .stats {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 18px;
        padding: 42px;
        align-content: center;
      }

      .stat {
        padding: 26px;
        border-radius: 30px;
        background: rgba(255, 255, 255, 0.62);
        border: 1px solid rgba(26, 20, 30, 0.08);
      }

      .stat-value {
        display: block;
        font-size: clamp(2.7rem, 6vw, 5rem);
        font-weight: 700;
        letter-spacing: -0.06em;
      }

      .stat-label {
        display: block;
        margin-top: 10px;
        color: var(--muted);
        line-height: 1.5;
      }

      .areas-header {
        padding: 8px 0 18px;
      }

      .areas-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 18px;
      }

      .area-card {
        padding: 24px;
        min-height: 260px;
      }

      .area-tag {
        display: inline-flex;
        padding: 8px 12px;
        border-radius: 999px;
        background: var(--lavender-soft);
        color: var(--ink);
        font-family: "IBM Plex Mono", "Courier New", monospace;
        font-size: 0.75rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }

      .area-card h3 {
        margin-top: 18px;
        font-size: clamp(1.8rem, 3vw, 2.6rem);
      }

      .area-illustration {
        height: 90px;
        margin-top: 26px;
        border-radius: 24px;
        background:
          radial-gradient(circle at 22% 50%, var(--lavender) 0 16%, transparent 17%),
          radial-gradient(circle at 50% 50%, rgba(26, 20, 30, 0.16) 0 14%, transparent 15%),
          radial-gradient(circle at 78% 50%, var(--silver) 0 18%, transparent 19%),
          linear-gradient(90deg, rgba(26, 20, 30, 0.1), rgba(170, 143, 255, 0.22), rgba(26, 20, 30, 0.1));
      }

      .footer {
        padding: 24px 0 48px;
      }

      .footer-card {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 20px;
        padding: 28px 30px;
        background: linear-gradient(135deg, rgba(26, 20, 30, 0.96), rgba(39, 28, 46, 0.96));
        color: white;
      }

      .footer-copy p {
        color: rgba(255, 255, 255, 0.7);
      }

      .footer-meta {
        font-family: "IBM Plex Mono", "Courier New", monospace;
        color: rgba(255, 255, 255, 0.6);
        font-size: 0.82rem;
      }

      @keyframes pulse {
        0%,
        100% {
          transform: scale(1);
          box-shadow: 0 0 0 0 rgba(170, 143, 255, 0.25);
        }

        50% {
          transform: scale(1.05);
          box-shadow: 0 0 0 14px rgba(170, 143, 255, 0);
        }
      }

      @media (max-width: 1080px) {
        .hero-grid,
        .mission-card,
        .platform-card,
        .network-card,
        .areas-grid {
          grid-template-columns: 1fr;
        }

        .mission-copy,
        .platform-copy,
        .network-copy {
          border-right: 0;
          border-bottom: 1px solid rgba(26, 20, 30, 0.08);
        }

        .platform-visual {
          min-height: 540px;
        }
      }

      @media (max-width: 720px) {
        .shell {
          width: min(100% - 20px, 1200px);
        }

        .nav {
          top: 10px;
          padding-top: 10px;
        }

        .nav-card,
        .footer-card {
          border-radius: 28px;
          padding: 16px;
        }

        .nav-card,
        .footer-card,
        .hero-actions {
          flex-direction: column;
          align-items: stretch;
        }

        .nav-links {
          justify-content: stretch;
        }

        .nav-links a,
        .button {
          text-align: center;
        }

        .hero-card,
        .mission-copy,
        .mission-quote,
        .platform-copy,
        .network-copy,
        .stats,
        .area-card {
          padding: 24px;
        }

        .hero-card,
        .hero-visual {
          min-height: auto;
        }

        .hero-scroll {
          position: static;
          margin-top: 28px;
        }

        .hero-visual {
          padding: 18px;
        }

        .hero-visual .panel-grid,
        .stats,
        .use-case-grid {
          grid-template-columns: 1fr;
        }
      }
    </style>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;700&family=IBM+Plex+Sans:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <div class="page">
      <header class="nav shell">
        <div class="nav-card">
          <a class="brand" href="#top" aria-label="Endpoint home">
            <span class="brand-mark" aria-hidden="true">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
                <path d="M3 3h5.4v1.2H4.2v4.2H3V3ZM15.6 3H21v5.4h-1.2V4.2h-4.2V3ZM4.2 15.6v4.2h4.2V21H3v-5.4h1.2ZM19.8 15.6H21V21h-5.4v-1.2h4.2v-4.2Z" fill="currentColor"></path>
                <path d="M10.04 7.8h2.52c.6 0 .99.1 1.17.3.2.18.3.58.3 1.18v5.46c0 .6-.1 1-.3 1.2-.18.18-.57.28-1.17.28h-2.52V7.8ZM16.42 12.86v1.9c0 .58-.1.97-.3 1.16-.18.18-.57.28-1.16.28h-4.92v-3.34h6.38ZM14.96 10.22v1.34c0 .54-.07.88-.22 1.02-.12.14-.43.22-.92.22h-3.78v-2.58h4.92ZM16.42 7.8v1.9c0 .6-.1.99-.3 1.17-.18.2-.57.3-1.16.3h-4.92V7.8h6.38Z" fill="currentColor"></path>
              </svg>
            </span>
            <span class="brand-word">Endpoint</span>
          </a>

          <nav class="nav-links" aria-label="Primary">
            <a href="/blog">Blog</a>
            <a class="button primary" href="https://cal.com/luis-pericchi/30min" target="_blank" rel="noreferrer">
              Book a call
            </a>
          </nav>
        </div>
      </header>

      <main id="top">
        <section class="hero">
          <div class="shell hero-grid">
            <article class="hero-card">
              <div class="eyebrow">AI agents for real-world evidence</div>
              <h1>Conduct any RWE study in minutes</h1>
              <p class="hero-copy">
                Scale evidence generation with our AI-powered platform, delivering instant insights from
                25M+ multimodal, longitudinal patient records.
              </p>

              <div class="hero-actions">
                <a class="button primary" href="https://cal.com/luis-pericchi/30min" target="_blank" rel="noreferrer">
                  Book call
                </a>
                <a class="button" href="#platform">See the platform</a>
              </div>

              <div class="hero-scroll mono">
                <span>Scroll to learn more</span>
              </div>
            </article>

            <aside class="hero-visual hero-card">
              <div class="panel main">
                <div class="panel-label">
                  <span class="mono">The Endpoint Data Network</span>
                  <span class="mono">25M+</span>
                </div>
                <div class="signal-map" aria-hidden="true"></div>
                <div class="signal-grid" aria-hidden="true"></div>
                <span class="signal-node" style="top: 28%; left: 24%;"></span>
                <span class="signal-node dark" style="top: 18%; left: 68%;"></span>
                <span class="signal-node" style="top: 65%; left: 74%;"></span>
                <span class="signal-node dark" style="top: 72%; left: 34%;"></span>
                <span class="signal-line" style="top: 30%; left: 26%; width: 42%; transform: rotate(-7deg);"></span>
                <span class="signal-line" style="top: 66%; left: 36%; width: 38%; transform: rotate(-14deg);"></span>
                <span class="signal-line" style="top: 24%; left: 64%; width: 14%; transform: rotate(68deg);"></span>
              </div>

              <div class="panel-grid">
                <div class="panel mini-orbit">
                  <div class="panel-label">
                    <span class="mono">Biomarkers</span>
                  </div>
                </div>

                <div class="panel mini-compass">
                  <div class="panel-label">
                    <span class="mono">Selection</span>
                  </div>
                  <svg viewBox="0 0 100 100" fill="none" aria-hidden="true">
                    <circle cx="50" cy="50" r="38" stroke="rgba(26,20,30,0.15)" />
                    <path d="M35 65L57 58L65 35L43 42L35 65Z" fill="#aa8fff" />
                    <circle cx="50" cy="50" r="6" fill="#1a141e" />
                  </svg>
                </div>

                <div class="panel mini-wave" style="grid-column: 1 / -1;">
                  <div class="panel-label">
                    <span class="mono">Multimodal signals</span>
                  </div>
                  <svg viewBox="0 0 300 100" fill="none" aria-hidden="true">
                    <path d="M6 62C28 54 49 50 72 50s46-5 69-10 45-10 74-8 49 10 79 25" stroke="#aa8fff" stroke-width="2" />
                    <path d="M6 34C24 44 44 52 70 58c27 6 47 6 72 6 24 0 47 3 73 11 19 6 42 15 73 24" stroke="#d9d9d9" stroke-width="2" />
                    <rect x="12" y="54" width="10" height="10" fill="#aa8fff" />
                    <rect x="72" y="45" width="10" height="10" fill="#aa8fff" />
